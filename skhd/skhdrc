# APPS #
#
# Safari
alt - s : run-external "open" "-a" "/Applications/Safari.app/Contents/MacOS/Safari"

# Obsidian
alt - o : run-external "open" "-a" "/Applications/Obsidian.app/Contents/MacOS/Obsidian"

# Close notifications
ralt - n : osascript ~/.config/skhd/applescripts/notifications.scpt

# QuickTime
alt - q : run-external "open" "-a" `/System/Applications/QuickTime Player.app/Contents/MacOS/QuickTime Player`

# FinalCut
alt - f : run-external "open" "-a" `/Applications/Final Cut Pro.app/Contents/MacOS/Final Cut Pro`

# Ghostty
alt - g : run-external "open" "-a" "/Applications/Ghostty.app"
